{
  "version": 8,
  "name": "GO HUNTER · Cyber Purple v2",
  "metadata": {
    "description": "Cyberpunk blue-violet theme with neon glow halos around roads"
  },
  "sources": {
    "openmaptiles": {
      "type": "vector",
      "url": "https://tiles.openfreemap.org/planet"
    }
  },
  "glyphs": "https://tiles.openfreemap.org/fonts/{fontstack}/{range}.pbf",
  "sprite": "https://tiles.openfreemap.org/sprites/v1/sprite",
  "layers": [
    { "id": "background", "type": "background", "paint": { "background-color": "#150a30" } },

    { "id": "landuse-residential", "type": "fill", "source": "openmaptiles", "source-layer": "landuse",
      "filter": ["==", "class", "residential"],
      "paint": { "fill-color": "#241552", "fill-opacity": 0.65 } },
    { "id": "landuse-commercial", "type": "fill", "source": "openmaptiles", "source-layer": "landuse",
      "filter": ["==", "class", "commercial"],
      "paint": { "fill-color": "#2a1860", "fill-opacity": 0.55 } },
    { "id": "landuse-industrial", "type": "fill", "source": "openmaptiles", "source-layer": "landuse",
      "filter": ["==", "class", "industrial"],
      "paint": { "fill-color": "#1f0f48", "fill-opacity": 0.7 } },

    { "id": "park", "type": "fill", "source": "openmaptiles", "source-layer": "park",
      "paint": { "fill-color": "#243854", "fill-opacity": 0.6 } },
    { "id": "park-outline", "type": "line", "source": "openmaptiles", "source-layer": "park",
      "paint": { "line-color": "#22D3EE", "line-opacity": 0.3, "line-width": 0.7 } },

    { "id": "landcover-wood", "type": "fill", "source": "openmaptiles", "source-layer": "landcover",
      "filter": ["==", "class", "wood"],
      "paint": { "fill-color": "#1f3050", "fill-opacity": 0.55 } },
    { "id": "landcover-grass", "type": "fill", "source": "openmaptiles", "source-layer": "landcover",
      "filter": ["==", "class", "grass"],
      "paint": { "fill-color": "#202842", "fill-opacity": 0.45 } },

    { "id": "water", "type": "fill", "source": "openmaptiles", "source-layer": "water",
      "paint": { "fill-color": "#080422", "fill-opacity": 1 } },
    { "id": "water-river", "type": "line", "source": "openmaptiles", "source-layer": "waterway",
      "filter": ["==", "class", "river"],
      "paint": { "line-color": "#22D3EE", "line-opacity": 0.4,
                 "line-width": ["interpolate", ["linear"], ["zoom"], 9, 0.5, 14, 1.5, 18, 3] } },
    { "id": "water-stream", "type": "line", "source": "openmaptiles", "source-layer": "waterway",
      "filter": ["!=", "class", "river"],
      "paint": { "line-color": "#22D3EE", "line-opacity": 0.2, "line-width": 0.6 } },

    { "id": "aeroway-runway", "type": "fill", "source": "openmaptiles", "source-layer": "aeroway",
      "filter": ["==", "$type", "Polygon"],
      "paint": { "fill-color": "#3d1f6e", "fill-opacity": 0.3 } },

    { "id": "road-motorway-glow", "type": "line", "source": "openmaptiles", "source-layer": "transportation",
      "filter": ["all", ["!=", "brunnel", "tunnel"], ["==", "class", "motorway"]],
      "paint": { "line-color": "#7B5CFF", "line-opacity": 0.5, "line-blur": 12,
                 "line-width": ["interpolate", ["linear"], ["zoom"], 5, 4, 18, 38] } },
    { "id": "road-trunk-glow", "type": "line", "source": "openmaptiles", "source-layer": "transportation",
      "filter": ["all", ["!=", "brunnel", "tunnel"], ["==", "class", "trunk"]],
      "paint": { "line-color": "#9D6BFF", "line-opacity": 0.4, "line-blur": 10,
                 "line-width": ["interpolate", ["linear"], ["zoom"], 6, 3, 18, 32] } },
    { "id": "road-primary-glow", "type": "line", "source": "openmaptiles", "source-layer": "transportation",
      "filter": ["all", ["!=", "brunnel", "tunnel"], ["==", "class", "primary"]],
      "paint": { "line-color": "#A78BFA", "line-opacity": 0.35, "line-blur": 8,
                 "line-width": ["interpolate", ["linear"], ["zoom"], 7, 2.5, 18, 26] } },
    { "id": "road-secondary-glow", "type": "line", "source": "openmaptiles", "source-layer": "transportation",
      "filter": ["all", ["!=", "brunnel", "tunnel"], ["==", "class", "secondary"]],
      "paint": { "line-color": "#C77FE0", "line-opacity": 0.3, "line-blur": 6,
                 "line-width": ["interpolate", ["linear"], ["zoom"], 9, 2, 18, 18] } },
    { "id": "road-tertiary-glow", "type": "line", "source": "openmaptiles", "source-layer": "transportation",
      "filter": ["all", ["!=", "brunnel", "tunnel"], ["==", "class", "tertiary"]],
      "paint": { "line-color": "#E879F9", "line-opacity": 0.22, "line-blur": 4,
                 "line-width": ["interpolate", ["linear"], ["zoom"], 11, 1.5, 18, 12] } },
    { "id": "road-minor-glow", "type": "line", "source": "openmaptiles", "source-layer": "transportation",
      "filter": ["all", ["!=", "brunnel", "tunnel"], ["in", "class", "minor", "service", "track", "path"]],
      "paint": { "line-color": "#F472B6", "line-opacity": 0.18, "line-blur": 3,
                 "line-width": ["interpolate", ["linear"], ["zoom"], 13, 1, 18, 7] } },

    { "id": "road-minor-casing", "type": "line", "source": "openmaptiles", "source-layer": "transportation",
      "filter": ["all", ["!=", "brunnel", "tunnel"], ["in", "class", "minor", "service", "track", "path"]],
      "paint": { "line-color": "#3d1f6e", "line-opacity": 0.4,
                 "line-width": ["interpolate", ["linear"], ["zoom"], 13, 0.6, 18, 4] } },
    { "id": "road-minor", "type": "line", "source": "openmaptiles", "source-layer": "transportation",
      "filter": ["all", ["!=", "brunnel", "tunnel"], ["in", "class", "minor", "service", "track", "path"]],
      "paint": { "line-color": "#A065D9", "line-opacity": 0.7,
                 "line-width": ["interpolate", ["linear"], ["zoom"], 13, 0.4, 18, 2.5] } },

    { "id": "road-tertiary-casing", "type": "line", "source": "openmaptiles", "source-layer": "transportation",
      "filter": ["all", ["!=", "brunnel", "tunnel"], ["==", "class", "tertiary"]],
      "paint": { "line-color": "#5b1a6e", "line-opacity": 0.6,
                 "line-width": ["interpolate", ["linear"], ["zoom"], 11, 0.6, 18, 9] } },
    { "id": "road-tertiary", "type": "line", "source": "openmaptiles", "source-layer": "transportation",
      "filter": ["all", ["!=", "brunnel", "tunnel"], ["==", "class", "tertiary"]],
      "paint": { "line-color": "#C77FE0", "line-opacity": 0.8,
                 "line-width": ["interpolate", ["linear"], ["zoom"], 11, 0.4, 18, 5] } },

    { "id": "road-secondary-casing", "type": "line", "source": "openmaptiles", "source-layer": "transportation",
      "filter": ["all", ["!=", "brunnel", "tunnel"], ["==", "class", "secondary"]],
      "paint": { "line-color": "#4a1a8c", "line-opacity": 0.75,
                 "line-width": ["interpolate", ["linear"], ["zoom"], 9, 0.6, 18, 13] } },
    { "id": "road-secondary", "type": "line", "source": "openmaptiles", "source-layer": "transportation",
      "filter": ["all", ["!=", "brunnel", "tunnel"], ["==", "class", "secondary"]],
      "paint": { "line-color": "#9D6BFF", "line-opacity": 0.95,
                 "line-width": ["interpolate", ["linear"], ["zoom"], 9, 0.5, 18, 8] } },

    { "id": "road-primary-casing", "type": "line", "source": "openmaptiles", "source-layer": "transportation",
      "filter": ["all", ["!=", "brunnel", "tunnel"], ["==", "class", "primary"]],
      "paint": { "line-color": "#3a1280", "line-opacity": 0.9,
                 "line-width": ["interpolate", ["linear"], ["zoom"], 7, 0.6, 18, 17] } },
    { "id": "road-primary", "type": "line", "source": "openmaptiles", "source-layer": "transportation",
      "filter": ["all", ["!=", "brunnel", "tunnel"], ["==", "class", "primary"]],
      "paint": { "line-color": "#7B5CFF", "line-opacity": 1,
                 "line-width": ["interpolate", ["linear"], ["zoom"], 7, 0.5, 18, 11] } },

    { "id": "road-trunk-casing", "type": "line", "source": "openmaptiles", "source-layer": "transportation",
      "filter": ["all", ["!=", "brunnel", "tunnel"], ["==", "class", "trunk"]],
      "paint": { "line-color": "#3a1280", "line-opacity": 0.95,
                 "line-width": ["interpolate", ["linear"], ["zoom"], 6, 0.6, 18, 19] } },
    { "id": "road-trunk", "type": "line", "source": "openmaptiles", "source-layer": "transportation",
      "filter": ["all", ["!=", "brunnel", "tunnel"], ["==", "class", "trunk"]],
      "paint": { "line-color": "#603FFF", "line-opacity": 1,
                 "line-width": ["interpolate", ["linear"], ["zoom"], 6, 0.6, 18, 13] } },

    { "id": "road-motorway-casing", "type": "line", "source": "openmaptiles", "source-layer": "transportation",
      "filter": ["all", ["!=", "brunnel", "tunnel"], ["==", "class", "motorway"]],
      "paint": { "line-color": "#2a0a78", "line-opacity": 1,
                 "line-width": ["interpolate", ["linear"], ["zoom"], 5, 0.7, 18, 23] } },
    { "id": "road-motorway", "type": "line", "source": "openmaptiles", "source-layer": "transportation",
      "filter": ["all", ["!=", "brunnel", "tunnel"], ["==", "class", "motorway"]],
      "paint": { "line-color": "#462AB6", "line-opacity": 1,
                 "line-width": ["interpolate", ["linear"], ["zoom"], 5, 0.7, 18, 16] } },

    { "id": "rail", "type": "line", "source": "openmaptiles", "source-layer": "transportation",
      "filter": ["==", "class", "rail"],
      "paint": { "line-color": "#22D3EE", "line-opacity": 0.6,
                 "line-width": ["interpolate", ["linear"], ["zoom"], 12, 0.5, 18, 2.5] } },
    { "id": "rail-dash", "type": "line", "source": "openmaptiles", "source-layer": "transportation",
      "filter": ["==", "class", "rail"],
      "paint": { "line-color": "#67E8F9", "line-opacity": 0.7, "line-dasharray": [2, 4],
                 "line-width": ["interpolate", ["linear"], ["zoom"], 14, 0.5, 18, 1.5] } },
    { "id": "transit", "type": "line", "source": "openmaptiles", "source-layer": "transportation",
      "filter": ["==", "class", "transit"],
      "paint": { "line-color": "#22D3EE", "line-opacity": 0.55, "line-width": 1.5 } },

    { "id": "building", "type": "fill", "source": "openmaptiles", "source-layer": "building",
      "minzoom": 13,
      "paint": { "fill-color": "#1a0d3a",
                 "fill-opacity": ["interpolate", ["linear"], ["zoom"], 13, 0, 14, 0.7],
                 "fill-outline-color": "#3d1f6e" } },

    { "id": "boundary-country", "type": "line", "source": "openmaptiles", "source-layer": "boundary",
      "filter": ["==", "admin_level", 2],
      "paint": { "line-color": "#22D3EE", "line-opacity": 0.65,
                 "line-width": ["interpolate", ["linear"], ["zoom"], 4, 0.8, 8, 1.5],
                 "line-dasharray": [3, 2] } },
    { "id": "boundary-state", "type": "line", "source": "openmaptiles", "source-layer": "boundary",
      "filter": ["==", "admin_level", 4],
      "paint": { "line-color": "#A78BFA", "line-opacity": 0.5,
                 "line-width": ["interpolate", ["linear"], ["zoom"], 6, 0.5, 12, 1.2],
                 "line-dasharray": [4, 2] } },
    { "id": "boundary-county", "type": "line", "source": "openmaptiles", "source-layer": "boundary",
      "filter": [">=", "admin_level", 6],
      "paint": { "line-color": "#7d4dbe", "line-opacity": 0.35, "line-width": 0.7,
                 "line-dasharray": [2, 2] } },

    { "id": "place-village", "type": "symbol", "source": "openmaptiles", "source-layer": "place",
      "filter": ["in", "class", "village", "hamlet", "neighbourhood"], "minzoom": 12,
      "layout": { "text-field": ["coalesce", ["get", "name:th"], ["get", "name"], ["get", "name:latin"]],
                  "text-font": ["Noto Sans Regular"],
                  "text-size": ["interpolate", ["linear"], ["zoom"], 12, 11, 16, 14] },
      "paint": { "text-color": "#C4B5FD", "text-halo-color": "#0a0218",
                 "text-halo-width": 1.5, "text-halo-blur": 0.5 } },
    { "id": "place-suburb", "type": "symbol", "source": "openmaptiles", "source-layer": "place",
      "filter": ["==", "class", "suburb"], "minzoom": 11,
      "layout": { "text-field": ["coalesce", ["get", "name:th"], ["get", "name"], ["get", "name:latin"]],
                  "text-font": ["Noto Sans Regular"],
                  "text-size": ["interpolate", ["linear"], ["zoom"], 11, 12, 16, 16] },
      "paint": { "text-color": "#DDD6FE", "text-halo-color": "#0a0218",
                 "text-halo-width": 1.8, "text-halo-blur": 0.5 } },
    { "id": "place-town", "type": "symbol", "source": "openmaptiles", "source-layer": "place",
      "filter": ["==", "class", "town"], "minzoom": 8,
      "layout": { "text-field": ["coalesce", ["get", "name:th"], ["get", "name"], ["get", "name:latin"]],
                  "text-font": ["Noto Sans Bold"],
                  "text-size": ["interpolate", ["linear"], ["zoom"], 8, 12, 14, 18] },
      "paint": { "text-color": "#E2E8FF", "text-halo-color": "#0a0218",
                 "text-halo-width": 2, "text-halo-blur": 0.5 } },
    { "id": "place-city", "type": "symbol", "source": "openmaptiles", "source-layer": "place",
      "filter": ["==", "class", "city"], "minzoom": 4,
      "layout": { "text-field": ["coalesce", ["get", "name:th"], ["get", "name"], ["get", "name:latin"]],
                  "text-font": ["Noto Sans Bold"],
                  "text-size": ["interpolate", ["linear"], ["zoom"], 4, 11, 14, 22] },
      "paint": { "text-color": "#FBB040", "text-halo-color": "#0a0218",
                 "text-halo-width": 2, "text-halo-blur": 0.5 } },
    { "id": "place-state", "type": "symbol", "source": "openmaptiles", "source-layer": "place",
      "filter": ["==", "class", "state"], "minzoom": 4, "maxzoom": 8,
      "layout": { "text-field": ["coalesce", ["get", "name:th"], ["get", "name"], ["get", "name:latin"]],
                  "text-font": ["Noto Sans Bold"],
                  "text-size": ["interpolate", ["linear"], ["zoom"], 4, 10, 8, 14] },
      "paint": { "text-color": "#A78BFA", "text-halo-color": "#0a0218", "text-halo-width": 1.5 } },
    { "id": "place-country", "type": "symbol", "source": "openmaptiles", "source-layer": "place",
      "filter": ["==", "class", "country"], "maxzoom": 6,
      "layout": { "text-field": ["coalesce", ["get", "name:th"], ["get", "name"], ["get", "name:latin"]],
                  "text-font": ["Noto Sans Bold"],
                  "text-size": ["interpolate", ["linear"], ["zoom"], 2, 12, 6, 22] },
      "paint": { "text-color": "#22D3EE", "text-halo-color": "#0a0218",
                 "text-halo-width": 2, "text-halo-blur": 1 } },

    { "id": "poi-major", "type": "symbol", "source": "openmaptiles", "source-layer": "poi",
      "filter": ["all",
        ["in", "class", "park", "stadium", "hospital", "university", "library", "museum", "townhall", "embassy", "place_of_worship", "attraction", "aerodrome"],
        ["<=", "rank", 3]],
      "minzoom": 13,
      "layout": { "text-field": ["coalesce", ["get", "name:th"], ["get", "name"], ["get", "name:latin"]],
                  "text-font": ["Noto Sans Regular"], "text-size": 11,
                  "text-anchor": "top", "text-offset": [0, 0.7], "text-max-width": 8 },
      "paint": { "text-color": "#FBB040", "text-halo-color": "#0a0218",
                 "text-halo-width": 1.5, "text-halo-blur": 0.3 } },
    { "id": "poi-transit", "type": "symbol", "source": "openmaptiles", "source-layer": "poi",
      "filter": ["all", ["in", "class", "railway", "bus", "ferry_terminal"], ["<=", "rank", 4]],
      "minzoom": 14,
      "layout": { "text-field": ["coalesce", ["get", "name:th"], ["get", "name"], ["get", "name:latin"]],
                  "text-font": ["Noto Sans Regular"], "text-size": 10,
                  "text-anchor": "top", "text-offset": [0, 0.6] },
      "paint": { "text-color": "#22D3EE", "text-halo-color": "#0a0218", "text-halo-width": 1.5 } },

    { "id": "road-name-major", "type": "symbol", "source": "openmaptiles", "source-layer": "transportation_name",
      "filter": ["in", "class", "motorway", "trunk", "primary"], "minzoom": 13,
      "layout": { "text-field": ["coalesce", ["get", "name:th"], ["get", "name"], ["get", "name:latin"]],
                  "text-font": ["Noto Sans Regular"],
                  "text-size": ["interpolate", ["linear"], ["zoom"], 13, 9, 18, 13],
                  "symbol-placement": "line", "symbol-spacing": 320, "text-padding": 4 },
      "paint": { "text-color": "#F9A8D4", "text-halo-color": "#0a0218",
                 "text-halo-width": 1.5, "text-halo-blur": 0.3 } },
    { "id": "road-name-minor", "type": "symbol", "source": "openmaptiles", "source-layer": "transportation_name",
      "filter": ["in", "class", "secondary", "tertiary", "minor"], "minzoom": 15,
      "layout": { "text-field": ["coalesce", ["get", "name:th"], ["get", "name"], ["get", "name:latin"]],
                  "text-font": ["Noto Sans Regular"],
                  "text-size": ["interpolate", ["linear"], ["zoom"], 15, 9, 18, 12],
                  "symbol-placement": "line", "symbol-spacing": 280, "text-padding": 4 },
      "paint": { "text-color": "#C4B5FD", "text-halo-color": "#0a0218", "text-halo-width": 1.2 } },

    { "id": "water-name", "type": "symbol", "source": "openmaptiles", "source-layer": "water_name",
      "filter": ["==", "$type", "Point"],
      "layout": { "text-field": ["coalesce", ["get", "name:th"], ["get", "name"], ["get", "name:latin"]],
                  "text-font": ["Noto Sans Italic"],
                  "text-size": ["interpolate", ["linear"], ["zoom"], 6, 10, 14, 14] },
      "paint": { "text-color": "#67E8F9", "text-halo-color": "#020108",
                 "text-halo-width": 1.5, "text-halo-blur": 0.5 } }
  ],
  "id": "cyber-purple-v2"
}
